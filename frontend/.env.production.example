# Production Environment Variables
# These should be set in Vercel Dashboard, not committed to git

# API Configuration
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com/api
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# App Configuration
NEXT_PUBLIC_APP_NAME="FreelanceHub Pro"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Environment
NODE_ENV=production

# Security
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=true

# Feature Flags
NEXT_PUBLIC_ENABLE_REGISTRATION=true
NEXT_PUBLIC_ENABLE_PASSWORD_RESET=true
NEXT_PUBLIC_ENABLE_EMAIL_VERIFICATION=true

# Development Settings (disabled in production)
NEXT_PUBLIC_DEBUG_MODE=false
NEXT_PUBLIC_SHOW_DEV_TOOLS=false
